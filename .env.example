# ============================================================
#   Cab Fare Comparator — Environment Variables
#   Copy this file to .env and fill in YOUR credentials
# ============================================================

# --- UBER ---
UBER_PHONE=+919876543210
UBER_PASSWORD=your_uber_password_here

# --- OLA ---
OLA_PHONE=+919876543210
OLA_PASSWORD=your_ola_password_here

# --- RAPIDO ---
RAPIDO_PHONE=+919876543210
RAPIDO_PASSWORD=your_rapido_password_here

# --- SETTINGS ---
# Auto-refresh interval in minutes (default: 5)
REFRESH_INTERVAL_MINUTES=5

# Run browser in headless mode? (True = no browser window, False = visible)
HEADLESS=False
